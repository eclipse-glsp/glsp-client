{
  "name": "workflow-standalone",
  "version": "2.7.0-next",
  "private": true,
  "description": "Standalone browser-app for the Workflow example",
  "homepage": "https://www.eclipse.org/glsp/",
  "bugs": "https://github.com/eclipse-glsp/glsp/issues",
  "repository": {
    "type": "git",
    "url": "https://github.com/eclipse-glsp/glsp-client.git"
  },
  "author": {
    "name": "Eclipse GLSP"
  },
  "contributors": [
    {
      "name": "Eclipse GLSP Project",
      "email": "glsp-dev@eclipse.org",
      "url": "https://projects.eclipse.org/projects/ecd.glsp"
    }
  ],
  "main": "lib/node/app",
  "browser": "lib/browser/app",
  "scripts": {
    "build": "yarn compile && yarn bundle",
    "build:browser": "yarn compile && yarn bundle:browser",
    "bundle": "webpack",
    "bundle:browser": "yarn ts-node ./scripts/download-server.ts --browser && webpack --env mode=browser",
    "clean": "rimraf lib *.tsbuildinfo app/bundle.js app/bundle.js.map app/wf-glsp-server-webworker.js app/css",
    "compile": "tsc -b",
    "dev": "yarn ts-node ./scripts/start.ts --dev",
    "dev:browser": "yarn ts-node ./scripts/start.ts --dev --browser",
    "lint": "eslint ./src",
    "start": "yarn ts-node ./scripts/start.ts",
    "start:browser": "yarn ts-node ./scripts/start.ts --browser",
    "start:server": "yarn ts-node ./scripts/start-node-server.ts",
    "watch": "tsc -w"
  },
  "dependencies": {
    "@eclipse-glsp-examples/workflow-glsp": "2.7.0-next",
    "@eclipse-glsp/client": "2.7.0-next"
  },
  "devDependencies": {
    "@types/tar": "6.1.5",
    "circular-dependency-plugin": "^5.2.2",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.7.1",
    "inversify": "^6.1.3",
    "source-map-loader": "^4.0.0",
    "style-loader": "^3.3.1",
    "webpack": "^5.74.0",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
